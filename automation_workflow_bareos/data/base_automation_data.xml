<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================================ -->
        <!-- CRM Lead                                                     -->
        <!-- ============================================================ -->
        <record id="automation_incoming_activity_crm_lead" model="base.automation">
            <field name="name">Incoming Message Activity (CRM Lead)</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="trigger">on_message_received</field>
            <field name="active" eval="True"/>
        </record>

        <record id="action_incoming_activity_crm_lead" model="ir.actions.server">
            <field name="name">Create Activity on Incoming Message (CRM Lead)</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="state">code</field>
            <field name="code">record._schedule_incoming_message_activity(user_field="user_id")</field>
            <field name="base_automation_id" ref="automation_incoming_activity_crm_lead"/>
        </record>

